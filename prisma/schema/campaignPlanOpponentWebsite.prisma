model CampaignPlanOpponentWebsite {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")

  opponent   CampaignPlanOpponent @relation(fields: [opponentId], references: [id], onDelete: Cascade)
  opponentId Int                  @map("opponent_id")

  url String

  @@index([opponentId])
  @@map("campaign_plan_opponent_website")
}
