model CampaignStrategy {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId Int      @unique @map("campaign_id")

  oppositionRunId    String? @map("opposition_run_id")
  opportunitiesRunId String? @map("opportunities_run_id")

  opportunities CampaignStrategyOpportunity[]
  challenges    CampaignStrategyChallenge[]
  opponents     CampaignStrategyOpponent[]

  @@map("campaign_strategy")
}
