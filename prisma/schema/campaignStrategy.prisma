model CampaignStrategy {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId Int      @unique @map("campaign_id")

  opportunities CampaignStrategyOpportunity[]
  challenges    CampaignStrategyChallenge[]
  opponents     CampaignStrategyOpponent[]

  // Section 7 community events — populated by CommunityEventsService via
  // Gemini search + structured + Braintrust. JSON over a relational table
  // because events are read whole and don't need indexed sub-queries.
  // Sidecar type: PrismaJson.CommunityEventsResult.
  communityEvents Json? @map("community_events")

  @@map("campaign_strategy")
}
