model CampaignStrategyChallenge {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")

  campaignStrategy   CampaignStrategy @relation(fields: [campaignStrategyId], references: [id], onDelete: Cascade)
  campaignStrategyId Int              @map("campaign_strategy_id")

  order   Int
  content String

  @@index([campaignStrategyId])
  @@map("campaign_strategy_challenge")
}
