model CampaignStrategyOpponent {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")

  campaignStrategy   CampaignStrategy @relation(fields: [campaignStrategyId], references: [id], onDelete: Cascade)
  campaignStrategyId Int              @map("campaign_strategy_id")

  fullName         String   @map("full_name")
  partyAffiliation String   @map("party_affiliation")
  incumbent        Boolean?

  @@index([campaignStrategyId])
  @@map("campaign_strategy_opponent")
}
