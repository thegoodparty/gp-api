{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": "swc",
    "typeCheck": true,
    "deleteOutDir": true,
    "assets": [
      { "include": "meetings/assets/**/*", "outDir": "dist" }
    ],
    "watchAssets": true
  },
  "generateOptions": {
    "spec": false
  }
}
