{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": "swc",
    "typeCheck": true,
    "deleteOutDir": true,
    "assets": [
      { "include": "meetings/assets/**/*", "outDir": "dist" },
      { "include": "generated/prisma/**/*.node", "outDir": "dist", "watchAssets": false },
      { "include": "generated/prisma/**/*.wasm", "outDir": "dist", "watchAssets": false },
      { "include": "generated/prisma/**/*.mjs", "outDir": "dist", "watchAssets": false },
      { "include": "generated/prisma/**/*.prisma", "outDir": "dist", "watchAssets": false },
      { "include": "generated/prisma/package.json", "outDir": "dist", "watchAssets": false }
    ],
    "watchAssets": true
  },
  "generateOptions": {
    "spec": false
  }
}
